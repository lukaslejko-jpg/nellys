generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum PuzzleType {
  PYRAMINX
}

enum PuzzleSessionStatus {
  DRAFT
  NEEDS_CONFIRMATION
  VALIDATED
  SOLVED
  COMPLETED
  FAILED
}

enum PuzzleInputMethod {
  MANUAL
  PHOTO
  VIDEO
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  passwordHash  String?
  role          UserRole        @default(USER)
  status        UserStatus      @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  sessions      PuzzleSession[]
  subscriptions Subscription[]
  aiUsageLogs   AiUsageLog[]
  payments      Payment[]
  consents      ConsentRecord[]
}

model SubscriptionPlan {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  description        String?
  price              Int
  currency           String         @default("EUR")
  billingInterval    String
  monthlySolveLimit  Int?
  featuresJson       Json
  active             Boolean        @default(true)
  recommended        Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  subscriptions      Subscription[]
}

model Subscription {
  id                     String           @id @default(cuid())
  userId                 String
  planId                 String
  provider               String
  providerCustomerId     String?
  providerSubscriptionId String?          @unique
  status                 String
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   SubscriptionPlan @relation(fields: [planId], references: [id])
  payments               Payment[]
}

model PuzzleSession {
  id                 String              @id @default(cuid())
  userId             String
  puzzleType         PuzzleType          @default(PYRAMINX)
  status             PuzzleSessionStatus @default(DRAFT)
  inputMethod        PuzzleInputMethod   @default(MANUAL)
  detectedStateJson  Json?
  correctedStateJson Json?
  solutionJson       Json?
  currentStep        Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  completedAt        DateTime?
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  images             PuzzleImage[]
  corrections        RecognitionCorrection[]
  aiUsageLogs        AiUsageLog[]

  @@index([userId, status])
}

model PuzzleImage {
  id              String        @id @default(cuid())
  sessionId       String
  sideIndex       Int
  storageKey      String
  orientationJson Json?
  recognitionJson Json?
  confidence      Float?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  session         PuzzleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model RecognitionCorrection {
  id             String        @id @default(cuid())
  sessionId      String
  fieldIndex     Int
  detectedColor  String?
  correctedColor String
  confidence     Float?
  createdAt      DateTime      @default(now())
  session        PuzzleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model AiUsageLog {
  id            String         @id @default(cuid())
  userId        String?
  sessionId     String?
  provider      String
  model         String
  operationType String
  inputUnits    Int           @default(0)
  outputUnits   Int           @default(0)
  estimatedCost Decimal?      @db.Decimal(10, 4)
  durationMs    Int?
  success       Boolean
  errorCode     String?
  createdAt     DateTime      @default(now())
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  session       PuzzleSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  subscriptionId    String?
  amount            Int
  currency          String        @default("EUR")
  status            String
  providerPaymentId String?       @unique
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadataJson Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model ConsentRecord {
  id          String    @id @default(cuid())
  userId      String
  consentType String
  version     String
  granted     Boolean
  grantedAt   DateTime?
  revokedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
}
